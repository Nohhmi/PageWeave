# Required: DashScope API key for runtime model calls.
DASHSCOPE_API_KEY=your_dashscope_api_key

# Required: DashScope compatible API base URL.
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional: Enable LangSmith tracing.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=ImageToArkTS

# Runtime in Docker: auto-connect container hdc to host emulator target.
# Set to 1 to enable hdc tconn at container startup.
HDC_AUTO_TCONN=1
# Example: host.docker.internal:5555
HDC_TCP_TARGET=host.docker.internal:5555
